{
  "name": "@open-notion/serializers",
  "version": "1.3.0",
  "description": "JSON → HTML / Markdown / React / PDF serializers for Open Notion editor content.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tabsircg/open-notion",
    "directory": "packages/serializers"
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "source": "./src/renderers/react.tsx",
      "types": "./dist/renderers/react.d.ts",
      "import": "./dist/renderers/react.js"
    },
    "./html": {
      "source": "./src/renderers/html/index.ts",
      "types": "./dist/renderers/html/index.d.ts",
      "import": "./dist/renderers/html/index.js"
    },
    "./markdown": {
      "source": "./src/renderers/markdown.ts",
      "types": "./dist/renderers/markdown.d.ts",
      "import": "./dist/renderers/markdown.js"
    },
    "./text": {
      "source": "./src/renderers/text.ts",
      "types": "./dist/renderers/text.d.ts",
      "import": "./dist/renderers/text.js"
    },
    "./pdf": {
      "source": "./src/renderers/pdf/index.tsx",
      "types": "./dist/renderers/pdf/index.d.ts",
      "import": "./dist/renderers/pdf/index.js"
    },
    "./toc": {
      "source": "./src/renderers/toc/index.tsx",
      "types": "./dist/renderers/toc/index.d.ts",
      "import": "./dist/renderers/toc/index.js"
    },
    "./const": {
      "source": "./src/renderers/html/dataAttr.ts",
      "import": "./dist/renderers/html/dataAttr.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.0.0",
    "@shikijs/core": "^4.0.2",
    "@shikijs/engine-javascript": "^4.0.2",
    "@shikijs/langs": "^4.0.2",
    "@shikijs/themes": "^4.0.2"
  },
  "devDependencies": {
    "@react-pdf/types": "^2.11.1",
    "@types/react": "^19.0.0",
    "react": "^19.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
