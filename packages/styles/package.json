{
  "name": "@open-notion/styles",
  "version": "1.0.0",
  "description": "Drop-in CSS for content rendered by Open Notion serializers.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tabsircg/open-notion",
    "directory": "packages/styles"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./open-notion-doc.css"
    },
    "./open-notion-doc.css": {
      "types": "./index.d.ts",
      "default": "./open-notion-doc.css"
    }
  },
  "files": [
    "open-notion-doc.css",
    "README.md",
    "index.d.ts"
  ],
  "publishConfig": {
    "access": "public"
  }
}
