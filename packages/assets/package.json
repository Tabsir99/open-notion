{
  "name": "@open-notion/assets",
  "version": "1.0.0",
  "description": "Drop-in CSS and JS assets for content rendered by Open Notion serializers.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tabsircg/open-notion",
    "directory": "packages/assets"
  },
  "exports": {
    "./doc.css": {
      "default": "./dist/open-notion-doc.css"
    },
    "./hydration.js": {
      "default": "./dist/open-notion-hydration.js"
    }
  },
  "files": [
    "dist/open-notion-doc.css",
    "dist/open-notion-hydration.js",
    "README.md"
  ],
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "@open-notion/serializers": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
