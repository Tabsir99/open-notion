{
  "name": "@open-notion/assets",
  "version": "1.3.1",
  "description": "Drop-in CSS, JS and Emoji assets for content rendered by Open Notion serializers.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tabsircg/open-notion",
    "directory": "packages/assets"
  },
  "exports": {
    "./doc.css": "./src/doc.css",
    "./emojis.json": "./src/emojis.json",
    "./hydration.js": {
      "source": "./src/hydration.ts",
      "import": "./dist/hydration.js"
    },
    "./package.json": {
      "import": "./package.json"
    }
  },
  "files": [
    "dist",
    "src/doc.css",
    "src/emojis.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsup"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "@open-notion/serializers": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
