{
  "name": "@tabsircg/open-notion",
  "version": "0.1.0",
  "description": "A plug-and-play, Notion-style rich text block editor built with React, Tiptap, and Shadcn (Base UI).",
  "keywords": [
    "react",
    "editor",
    "notion",
    "tiptap",
    "block-editor",
    "shadcn",
    "rich-text"
  ],
  "author": "tabsircg",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && pnpm build:emojis && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:emojis": "tsx ./scripts/build-emojis.ts",
    "build:registry": "shadcn build",
    "typecheck": "tsc -b && rm -rf dist"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@devicon/react": "^0.0.3",
    "@floating-ui/dom": "^1.7.6",
    "@fontsource-variable/geist": "^5.2.8",
    "@shikijs/core": "^4.0.2",
    "@shikijs/engine-javascript": "^4.0.2",
    "@shikijs/langs": "^4.0.2",
    "@shikijs/themes": "^4.0.2",
    "@tiptap/core": "^3.22.3",
    "@tiptap/extension-blockquote": "^3.22.3",
    "@tiptap/extension-bold": "^3.22.3",
    "@tiptap/extension-code": "^3.22.3",
    "@tiptap/extension-code-block": "^3.22.3",
    "@tiptap/extension-document": "^3.22.3",
    "@tiptap/extension-hard-break": "^3.22.3",
    "@tiptap/extension-heading": "^3.22.3",
    "@tiptap/extension-horizontal-rule": "^3.22.3",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-italic": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/extension-list": "^3.22.3",
    "@tiptap/extension-paragraph": "^3.22.3",
    "@tiptap/extension-strike": "^3.22.3",
    "@tiptap/extension-table": "^3.22.3",
    "@tiptap/extension-text": "^3.22.3",
    "@tiptap/extension-text-align": "^3.22.3",
    "@tiptap/extension-text-style": "^3.22.3",
    "@tiptap/extension-underline": "^3.22.3",
    "@tiptap/extensions": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/suggestion": "^3.22.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "emoji-regex": "^10.3.0",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "emojibase-data": "^17.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "shadcn": "^4.1.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
