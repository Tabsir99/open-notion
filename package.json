{
  "name": "open-notion",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "pnpm --filter playground dev",
    "build": "pnpm -r --sort build",
    "build:serializers": "pnpm --filter @open-notion/serializers build",
    "build:assets": "pnpm --filter @open-notion/assets build",
    "build:editor": "pnpm --filter @open-notion/editor build",
    "build:playground": "pnpm --filter playground build",
    "start:playground": "pnpm --filter playground start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "publish:serializers": "pnpm --filter @open-notion/serializers publish --access public",
    "publish:assets": "pnpm --filter @open-notion/assets publish --access public",
    "publish:editor": "pnpm --filter @open-notion/editor publish --access public",
    "clean:dist": "rm -rf packages/*/dist apps/*/dist",
    "clean": "rm -rf node_modules packages/*/node_modules apps/*/node_modules"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.25.12"
    }
  }
}
